# ── FastAPI backend ─────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# In production, set this to the public URL of your Streamlit service.
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Streamlit frontend ───────────────────────────────────────────────────────
# Full URL of the FastAPI backend.
# When using docker compose this is http://api:8000 (internal service name).
API_BASE_URL=http://localhost:8000
